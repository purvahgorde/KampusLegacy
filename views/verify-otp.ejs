<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>KampusLegacy - Verify Email</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#135bec",
                        "background-light": "#f6f6f8",
                        "background-dark": "#101622",
                    },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                },
            },
        }
    </script>
    <style>
        .otp-input {
            width: 52px;
            height: 60px;
            font-size: 24px;
            font-weight: 800;
            text-align: center;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            outline: none;
            transition: all 0.2s;
            background: white;
            color: #101622;
        }
        .otp-input:focus {
            border-color: #135bec;
            box-shadow: 0 0 0 4px rgba(19,91,236,0.12);
            transform: scale(1.05);
        }
        .otp-input.filled {
            border-color: #135bec;
            background: #f0f5ff;
            color: #135bec;
        }
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-6px); }
            75% { transform: translateX(6px); }
        }
        .shake { animation: shake 0.4s ease; }
        
        /* Dark mode */
        .dark .otp-input {
            background: #1a2332;
            border-color: #334155;
            color: white;
        }
        .dark .otp-input.filled {
            background: rgba(19,91,236,0.15);
            border-color: #135bec;
            color: #60a5fa;
        }

        #countdown-ring {
            stroke-dasharray: 251;
            stroke-dashoffset: 0;
            transition: stroke-dashoffset 1s linear;
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased min-h-screen flex items-center justify-center p-4">
    <div class="flex w-full max-w-5xl min-h-[600px] rounded-3xl overflow-hidden shadow-2xl bg-white dark:bg-[#1a2332]">
        <!-- Left: Illustration / Branding -->
        <div class="hidden lg:flex flex-col justify-between w-2/5 bg-gradient-to-b from-primary to-blue-700 p-12 text-white relative overflow-hidden">
            <!-- BG decoration -->
            <div class="absolute -top-24 -left-24 w-72 h-72 rounded-full bg-white/5"></div>
            <div class="absolute -bottom-20 -right-20 w-80 h-80 rounded-full bg-white/5"></div>

            <a href="/" class="flex items-center gap-3 relative z-10">
                <svg class="h-10 w-10" fill="none" viewBox="0 0 48 48">
                    <path d="M8.57829 8.57829C5.52816 11.6284 3.451 15.5145 2.60947 19.7452C1.76794 23.9758 2.19984 28.361 3.85056 32.3462C5.50128 36.3314 8.29667 39.7376 11.8832 42.134C15.4698 44.5305 19.6865 45.8096 24 45.8096C28.3135 45.8096 32.5302 44.5305 36.1168 42.134C39.7033 39.7375 42.4987 36.3314 44.1494 32.3462C45.8002 28.361 46.2321 23.9758 45.3905 19.7452C44.549 15.5145 42.4718 11.6284 39.4217 8.57829L24 24L8.57829 8.57829Z" fill="white"/>
                </svg>
                <span class="text-2xl font-bold">KampusLegacy</span>
            </a>

            <div class="relative z-10 space-y-6">
                <!-- Animated email icon -->
                <div class="w-24 h-24 rounded-3xl bg-white/10 backdrop-blur-sm flex items-center justify-center mb-8 border border-white/20">
                    <span class="material-symbols-outlined text-5xl text-white">mark_email_read</span>
                </div>
                <h2 class="text-3xl font-black tracking-tight leading-tight">Almost there!<br/>Check your inbox.</h2>
                <p class="text-white/70 text-base leading-relaxed">We sent a 6-digit verification code to your email. Enter it to activate your account and start your journey.</p>
                
                <div class="space-y-3 pt-4">
                    <div class="flex items-center gap-3">
                        <span class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center text-sm font-bold flex-shrink-0">✓</span>
                        <span class="text-white/80 text-sm">Secure OTP verification</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center text-sm font-bold flex-shrink-0">✓</span>
                        <span class="text-white/80 text-sm">Code expires in 10 minutes</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center text-sm font-bold flex-shrink-0">✓</span>
                        <span class="text-white/80 text-sm">Free to resend anytime</span>
                    </div>
                </div>
            </div>

            <p class="text-white/40 text-xs relative z-10">© 2026 KampusLegacy</p>
        </div>

        <!-- Right: OTP Form -->
        <div class="flex-1 flex flex-col justify-center p-8 sm:p-14 lg:p-16">
            <!-- Mobile logo -->
            <a href="/" class="flex items-center gap-2 mb-10 lg:hidden">
                <svg class="h-8 w-8 text-primary" fill="none" viewBox="0 0 48 48">
                    <path d="M8.57829 8.57829C5.52816 11.6284 3.451 15.5145 2.60947 19.7452C1.76794 23.9758 2.19984 28.361 3.85056 32.3462C5.50128 36.3314 8.29667 39.7376 11.8832 42.134C15.4698 44.5305 19.6865 45.8096 24 45.8096C28.3135 45.8096 32.5302 44.5305 36.1168 42.134C39.7033 39.7375 42.4987 36.3314 44.1494 32.3462C45.8002 28.361 46.2321 23.9758 45.3905 19.7452C44.549 15.5145 42.4718 11.6284 39.4217 8.57829L24 24L8.57829 8.57829Z" fill="currentColor"/>
                </svg>
                <span class="text-xl font-bold text-slate-900 dark:text-white">KampusLegacy</span>
            </a>

            <div class="mb-8">
                <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest mb-6">
                    <span class="material-symbols-outlined text-sm">verified</span>
                    Email Verification
                </div>
                <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight mb-2">Enter your code</h1>
                <p class="text-slate-500 dark:text-slate-400 font-medium">
                    We sent a 6-digit code to<br/>
                    <span class="font-bold text-slate-900 dark:text-white"><%= email %></span>
                </p>
            </div>

            <!-- Alert messages -->
            <% if (typeof error !== 'undefined' && error) { %>
                <div id="alert-box" class="mb-6 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-4 flex items-center gap-3">
                    <span class="material-symbols-outlined text-red-500 text-xl flex-shrink-0">error</span>
                    <p class="text-sm font-medium text-red-700 dark:text-red-300"><%= error %></p>
                </div>
            <% } %>
            <% if (typeof success !== 'undefined' && success) { %>
                <div id="alert-box" class="mb-6 rounded-xl bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 p-4 flex items-center gap-3">
                    <span class="material-symbols-outlined text-emerald-500 text-xl flex-shrink-0">check_circle</span>
                    <p class="text-sm font-medium text-emerald-700 dark:text-emerald-300"><%= success %></p>
                </div>
            <% } %>

            <!-- OTP Inputs -->
            <form id="otp-form" method="POST" action="/auth/verify-otp">
                <input type="hidden" name="email" value="<%= email %>" />
                <input type="hidden" name="otp" id="otp-hidden" />
                
                <div class="flex gap-3 justify-start mb-8" id="otp-boxes">
                    <input class="otp-input" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="one-time-code" />
                    <input class="otp-input" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" />
                    <input class="otp-input" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" />
                    <input class="otp-input" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" />
                    <input class="otp-input" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" />
                    <input class="otp-input" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]" />
                </div>

                <!-- Timer -->
                <div class="flex items-center gap-3 mb-8">
                    <div class="relative w-10 h-10">
                        <svg class="w-full h-full -rotate-90" viewBox="0 0 88 88">
                            <circle cx="44" cy="44" r="40" fill="none" stroke="#e2e8f0" stroke-width="8"/>
                            <circle id="countdown-ring" cx="44" cy="44" r="40" fill="none" stroke="#135bec" stroke-width="8" stroke-linecap="round"/>
                        </svg>
                        <span id="countdown-text" class="absolute inset-0 flex items-center justify-center text-xs font-black text-primary">10:00</span>
                    </div>
                    <p class="text-slate-500 dark:text-slate-400 text-sm font-medium">Code expires in <span id="timer-label" class="font-bold text-slate-900 dark:text-white">10:00</span></p>
                </div>

                <button type="submit" id="verify-btn"
                    class="w-full py-4 bg-primary text-white font-black text-base rounded-2xl shadow-xl shadow-primary/25 hover:bg-blue-700 active:scale-95 transition-all disabled:opacity-50 disabled:cursor-not-allowed disabled:scale-100 flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">verified_user</span>
                    Verify & Continue
                </button>
            </form>

            <!-- Resend -->
            <div class="mt-6 text-center">
                <p class="text-slate-500 dark:text-slate-400 text-sm font-medium">Didn't receive the code?</p>
                <form method="POST" action="/auth/resend-otp" class="inline">
                    <input type="hidden" name="email" value="<%= email %>" />
                    <button type="submit" id="resend-btn"
                        class="mt-2 text-primary font-bold text-sm hover:text-blue-700 transition-colors disabled:opacity-40 disabled:cursor-not-allowed flex items-center gap-1 mx-auto">
                        <span class="material-symbols-outlined text-sm">refresh</span>
                        Resend Code
                    </button>
                </form>
            </div>

            <div class="mt-8 text-center">
                <a href="/auth/logout" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 text-sm font-medium transition-colors flex items-center gap-1.5 justify-center">
                    <span class="material-symbols-outlined text-sm">arrow_back</span>
                    Back to Sign Up
                </a>
            </div>
        </div>
    </div>

    <script>
        // ─── OTP Input Management ──────────────────────────────
        const inputs = document.querySelectorAll('.otp-input');
        const hiddenOtp = document.getElementById('otp-hidden');
        const form = document.getElementById('otp-form');
        const verifyBtn = document.getElementById('verify-btn');
        const otpBoxes = document.getElementById('otp-boxes');

        inputs.forEach((input, i) => {
            input.addEventListener('input', (e) => {
                const val = e.target.value.replace(/[^0-9]/g, '');
                e.target.value = val;
                if (val) {
                    input.classList.add('filled');
                    if (i < inputs.length - 1) inputs[i + 1].focus();
                } else {
                    input.classList.remove('filled');
                }
                updateHiddenOtp();
            });

            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && !input.value && i > 0) {
                    inputs[i - 1].focus();
                    inputs[i - 1].value = '';
                    inputs[i - 1].classList.remove('filled');
                    updateHiddenOtp();
                }
            });

            input.addEventListener('paste', (e) => {
                e.preventDefault();
                const paste = e.clipboardData.getData('text').replace(/[^0-9]/g, '').slice(0, 6);
                paste.split('').forEach((char, idx) => {
                    if (inputs[idx]) {
                        inputs[idx].value = char;
                        inputs[idx].classList.add('filled');
                    }
                });
                updateHiddenOtp();
                const nextEmpty = [...inputs].findIndex(inp => !inp.value);
                if (nextEmpty !== -1) inputs[nextEmpty].focus();
                else inputs[5].focus();
            });
        });

        function updateHiddenOtp() {
            hiddenOtp.value = [...inputs].map(i => i.value).join('');
        }

        form.addEventListener('submit', (e) => {
            const otp = hiddenOtp.value;
            if (otp.length !== 6) {
                e.preventDefault();
                otpBoxes.classList.add('shake');
                setTimeout(() => otpBoxes.classList.remove('shake'), 400);
            }
        });

        // ─── Countdown Timer ───────────────────────────────────
        const ring = document.getElementById('countdown-ring');
        const timerLabel = document.getElementById('timer-label');
        const countdownText = document.getElementById('countdown-text');
        const totalSeconds = 600; // 10 minutes
        const circumference = 2 * Math.PI * 40; // ≈ 251
        ring.style.strokeDasharray = circumference;
        ring.style.strokeDashoffset = 0;

        let secondsLeft = totalSeconds;

        const timer = setInterval(() => {
            secondsLeft--;
            if (secondsLeft <= 0) {
                clearInterval(timer);
                secondsLeft = 0;
                verifyBtn.disabled = true;
                timerLabel.textContent = 'Expired';
                countdownText.textContent = '0:00';
                ring.style.stroke = '#ef4444';
            }
            const mins = Math.floor(secondsLeft / 60);
            const secs = secondsLeft % 60;
            const label = `${mins}:${secs.toString().padStart(2, '0')}`;
            timerLabel.textContent = label;
            countdownText.textContent = label;
            const offset = circumference * (1 - secondsLeft / totalSeconds);
            ring.style.strokeDashoffset = offset;

            if (secondsLeft <= 60) {
                ring.style.stroke = '#ef4444';
            } else if (secondsLeft <= 180) {
                ring.style.stroke = '#f59e0b';
            }
        }, 1000);

        // Auto-focus first input
        inputs[0].focus();
    </script>
</body>
</html>
