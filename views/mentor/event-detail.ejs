<%
function getStatusStyle(status) {
    if (status === 'registered') return 'bg-blue-50 text-blue-700 dark:bg-blue-900/20 dark:text-blue-400 border border-blue-200 dark:border-blue-800/50';
    if (status === 'attended') return 'bg-green-50 text-green-700 dark:bg-green-900/20 dark:text-green-400 border border-green-200 dark:border-green-800/50';
    if (status === 'cancelled') return 'bg-red-50 text-red-700 dark:bg-red-900/20 dark:text-red-400 border border-red-200 dark:border-red-800/50';
    return '';
}
%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title><%= event.title %> - KampusLegacy</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: { "primary": "#135bec", "primary-light": "#e8effd", "background-light": "#f6f6f8", "background-dark": "#101622" },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                },
            },
        }
    </script>
    <style>
        .scrollbar-thin::-webkit-scrollbar { width: 4px; }
        .scrollbar-thin::-webkit-scrollbar-track { background: transparent; }
        .scrollbar-thin::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 99px; }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased overflow-hidden">
<div class="flex h-screen w-full">

    <!-- Sidebar -->
    <aside class="w-64 flex-shrink-0 border-r border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 flex flex-col justify-between hidden md:flex">
        <div class="flex flex-col h-full">
            <div class="p-6">
                <a href="/" class="flex items-center gap-3 mb-8">
                    <div class="h-10 w-10 text-primary">
                        <svg class="h-full w-full" fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                            <path d="M8.57829 8.57829C5.52816 11.6284 3.451 15.5145 2.60947 19.7452C1.76794 23.9758 2.19984 28.361 3.85056 32.3462C5.50128 36.3314 8.29667 39.7376 11.8832 42.134C15.4698 44.5305 19.6865 45.8096 24 45.8096C28.3135 45.8096 32.5302 44.5305 36.1168 42.134C39.7033 39.7375 42.4987 36.3314 44.1494 32.3462C45.8002 28.361 46.2321 23.9758 45.3905 19.7452C44.549 15.5145 42.4718 11.6284 39.4217 8.57829L24 24L8.57829 8.57829Z" fill="currentColor"></path>
                        </svg>
                    </div>
                    <div>
                        <h1 class="text-slate-900 dark:text-white text-base font-bold leading-none">KampusLegacy</h1>
                        <p class="text-slate-500 dark:text-slate-400 text-xs font-medium mt-1">Mentor Portal</p>
                    </div>
                </a>
                <nav class="flex flex-col gap-1">
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 hover:text-slate-900 transition-colors" href="/mentor/home">
                        <span class="material-symbols-outlined text-[20px]">home</span><span class="text-sm">Home</span>
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 hover:text-slate-900 transition-colors" href="/mentor/dashboard">
                        <span class="material-symbols-outlined text-[20px]">dashboard</span><span class="text-sm">Dashboard</span>
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 hover:text-slate-900 transition-colors" href="/mentor/requests">
                        <span class="material-symbols-outlined text-[20px]">group</span><span class="text-sm">My Mentees</span>
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-primary/10 text-primary font-medium transition-colors" href="/mentor/events">
                        <span class="material-symbols-outlined text-[20px]">event</span><span class="text-sm">Events</span>
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 hover:text-slate-900 transition-colors" href="/mentor/opportunities">
                        <span class="material-symbols-outlined text-[20px]">work</span><span class="text-sm">Opportunities</span>
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 hover:text-slate-900 transition-colors" href="/mentor/messages">
                        <span class="material-symbols-outlined text-[20px]">chat_bubble</span><span class="text-sm">Messages</span>
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 hover:text-slate-900 transition-colors" href="/mentor/resources">
                        <span class="material-symbols-outlined text-[20px]">menu_book</span><span class="text-sm">Resources</span>
                    </a>
                </nav>
            </div>
            <div class="p-6 border-t border-slate-200 dark:border-slate-800">
                <div
                    onclick="openProfilePopup()"
                    class="flex items-center gap-3 p-2 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors cursor-pointer group">
                    <div class="h-9 w-9 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-sm flex-shrink-0 group-hover:scale-110 transition-transform">
                        <%= user.name.charAt(0).toUpperCase() %>
                    </div>
                    <div class="min-w-0 flex-1">
                        <p class="text-sm font-medium text-slate-900 dark:text-white truncate"><%= user.name %></p>
                        <p class="text-xs text-slate-500 dark:text-slate-400 truncate flex items-center gap-1"><span class="material-symbols-outlined text-xs">edit</span>View Profile</p>
                    </div>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col h-full overflow-hidden">
        <header class="h-16 flex items-center justify-between px-6 lg:px-8 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 shrink-0">
            <div class="flex items-center gap-4">
                <a href="/mentor/events" class="p-2 -ml-2 text-slate-400 hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full transition-colors">
                    <span class="material-symbols-outlined">arrow_back</span>
                </a>
                <div class="max-w-md truncate">
                    <h2 class="text-lg font-bold text-slate-900 dark:text-white leading-tight truncate"><%= event.title %></h2>
                    <p class="text-xs text-slate-500 font-medium">Created <%= new Date(event.createdAt).toLocaleDateString() %></p>
                </div>
            </div>
            <div class="flex items-center gap-3">
                <button onclick="deleteEvent()" class="flex items-center gap-2 px-3 py-1.5 text-sm font-semibold text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors">
                    <span class="material-symbols-outlined text-[18px]">delete</span> Delete Event
                </button>
            </div>
        </header>

        <main class="flex-1 overflow-y-auto p-6 lg:p-8 scrollbar-thin">
            
            <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
                <!-- Left: Details Panel -->
                <div class="xl:col-span-1 space-y-6">
                    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                        <!-- Banner Image -->
                        <div class="h-48 w-full border-b border-slate-200 dark:border-slate-800">
                            <img src="<%= event.bannerImage %>" alt="Event Banner" class="w-full h-full object-cover" />
                        </div>
                        
                        <div class="p-6">
                            <h3 class="font-bold text-slate-900 dark:text-white mb-4">Event Details</h3>
                            
                            <div class="space-y-4">
                                <div>
                                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Date & Time</p>
                                    <p class="text-sm font-medium text-slate-900 dark:text-slate-300">
                                        <%= new Date(event.date).toLocaleDateString(undefined, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %><br/>
                                        <%= event.time %>
                                    </p>
                                </div>
                                <div>
                                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Mode & Location</p>
                                    <span class="inline-flex items-center rounded px-2.5 py-0.5 text-xs font-medium bg-indigo-50 text-indigo-700 dark:bg-indigo-900/20 dark:text-indigo-300 mb-1">
                                        <%= event.mode %>
                                    </span>
                                    <p class="text-sm font-medium text-slate-900 dark:text-slate-300"><%= event.location %></p>
                                </div>
                                <div>
                                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Status</p>
                                    <p class="text-sm font-medium <%= event.isActive ? 'text-green-600' : 'text-slate-500' %>">
                                        <%= event.isActive ? 'Registration Open' : 'Closed' %>
                                    </p>
                                </div>
                                <div>
                                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Registration Type</p>
                                    <p class="text-sm font-medium text-slate-900 dark:text-slate-300 flex flex-col gap-1">
                                        <% if (event.registrationMode === 'internal') { %>
                                            <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-[16px] text-primary">how_to_reg</span> Tracking Internally</span>
                                        <% } else { %>
                                            <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-[16px] text-primary">link</span> External Link</span>
                                            <a href="<%= event.externalLink %>" target="_blank" class="text-primary text-xs break-all hover:underline"><%= event.externalLink %></a>
                                        <% } %>
                                    </p>
                                </div>
                            </div>

                            <hr class="my-5 border-slate-100 dark:border-slate-800">
                            
                            <div>
                                <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Description</p>
                                <p class="text-sm text-slate-700 dark:text-slate-300 whitespace-pre-wrap leading-relaxed"><%= event.description %></p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right: Registrations Panel -->
                <div class="xl:col-span-2 space-y-6">
                    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col items-center justify-center p-6 sm:p-0 sm:flex-row sm:divide-x divide-slate-100 dark:divide-slate-800">
                        <div class="w-full sm:w-1/3 p-6 text-center">
                            <p class="text-sm text-slate-500 font-medium mb-1">Total Views</p>
                            <p class="text-3xl font-bold text-slate-900 dark:text-white"><%= event.views %></p>
                        </div>
                        <div class="w-full sm:w-1/3 p-6 text-center">
                            <p class="text-sm text-slate-500 font-medium mb-1">Registrations</p>
                            <p class="text-3xl font-bold text-primary"><%= registrations.length %></p>
                        </div>
                        <div class="w-full sm:w-1/3 p-6 text-center">
                            <p class="text-sm text-slate-500 font-medium mb-1">Attended</p>
                            <p class="text-3xl font-bold text-green-600"><%= registrations.filter(r => r.status === 'attended').length %></p>
                        </div>
                    </div>

                    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
                        <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/50">
                            <h3 class="font-bold text-slate-900 dark:text-white">Attendees (<%= registrations.length %>)</h3>
                        </div>
                        
                        <% if (event.registrationMode === 'external') { %>
                            <div class="p-16 text-center">
                                <span class="material-symbols-outlined text-5xl text-slate-300 dark:text-slate-700 mb-3">link</span>
                                <h4 class="text-slate-900 dark:text-white font-medium mb-1">External Registration Mode</h4>
                                <p class="text-sm text-slate-500 max-w-sm mx-auto">This event is set to redirect students to an external link. Attendee tracking is managed on your external platform.</p>
                            </div>
                        <% } else if (registrations.length === 0) { %>
                            <div class="p-16 text-center">
                                <span class="material-symbols-outlined text-5xl text-slate-300 dark:text-slate-700 mb-3">person_off</span>
                                <p class="text-slate-500 font-medium">No registrations yet.</p>
                            </div>
                        <% } else { %>
                            <div class="overflow-x-auto">
                                <table class="w-full text-left border-collapse">
                                    <thead>
                                        <tr class="border-b border-slate-200 dark:border-slate-800 text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400 font-semibold">
                                            <th class="px-6 py-4">Student</th>
                                            <th class="px-6 py-4">Registered On</th>
                                            <th class="px-6 py-4">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                                        <% registrations.forEach(function(reg) { %>
                                            <tr class="group hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                                                <td class="px-6 py-4">
                                                    <div class="flex items-center gap-3">
                                                        <div class="h-8 w-8 rounded-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center font-bold text-xs text-slate-600 dark:text-slate-300">
                                                            <%= reg.student.name.charAt(0) %>
                                                        </div>
                                                        <div>
                                                            <p class="text-sm font-semibold text-slate-900 dark:text-white"><%= reg.student.name %></p>
                                                            <p class="text-xs text-slate-500"><%= reg.student.email %></p>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="px-6 py-4 text-sm text-slate-500">
                                                    <%= new Date(reg.registeredAt).toLocaleDateString() %><br/>
                                                    <%= new Date(reg.registeredAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                                                </td>
                                                <td class="px-6 py-4">
                                                    <select onchange="updateStatus('<%= reg._id %>', this.value)" class="text-xs font-semibold rounded-lg px-2.5 py-1 text-center cursor-pointer outline-none transition-colors appearance-none <%= getStatusStyle(reg.status) %> pr-8" style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22currentColor%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right .5rem top 50%; background-size: .65rem auto;">
                                                        <option value="registered" <%= reg.status === 'registered' ? 'selected' : '' %>>Registered</option>
                                                        <option value="attended" <%= reg.status === 'attended' ? 'selected' : '' %>>Attended</option>
                                                        <option value="cancelled" <%= reg.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                                                    </select>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

        </main>
    </div>
</div>

<script>
    async function updateStatus(regId, status) {
        try {
            const res = await fetch(`/mentor/events/registrations/${regId}/status`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });
            const data = await res.json();
            if (data.success) {
                location.reload(); // Reload to update styles and stats
            } else {
                alert('Failed to update status');
            }
        } catch (e) {
            alert('Network error');
        }
    }

    async function deleteEvent() {
        if (!confirm('Are you sure you want to delete this event? This will permanently remove all registration records.')) return;
        
        try {
            const res = await fetch(`/mentor/events/<%= event._id %>`, { method: 'DELETE' });
            const data = await res.json();
            if (data.success) {
                window.location.href = '/mentor/events';
            } else {
                alert(data.error || 'Failed to delete event');
            }
        } catch (e) {
            alert('Network error');
        }
    }
</script>
    <%- include('../partials/profile-popup', { user, role: 'mentor' }) %>
</body>
</html>
