<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>KampusLegacy - Mentor Dashboard</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#135bec",
                        "primary-content": "#ffffff",
                        "primary-dark": "#0e45b5",
                        "primary-light": "#ebf2fe",
                        "background-light": "#f6f6f8",
                        "background-dark": "#101622",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
</head>

<body
    class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased overflow-hidden">
    <div class="flex h-screen w-full bg-background-light dark:bg-background-dark">
        <!-- Sidebar -->
        <aside
            class="w-64 flex-shrink-0 border-r border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 flex flex-col justify-between transition-all duration-300">
            <div class="flex flex-col h-full">
                <div class="p-6">
                    <a href="/" class="flex items-center gap-3 mb-8">
                        <div class="h-10 w-10 text-primary">
                            <svg class="h-full w-full" fill="none" viewBox="0 0 48 48"
                                xmlns="http://www.w3.org/2000/svg">
                                <g clip-path="url(#clip0_6_319)">
                                    <path
                                        d="M8.57829 8.57829C5.52816 11.6284 3.451 15.5145 2.60947 19.7452C1.76794 23.9758 2.19984 28.361 3.85056 32.3462C5.50128 36.3314 8.29667 39.7376 11.8832 42.134C15.4698 44.5305 19.6865 45.8096 24 45.8096C28.3135 45.8096 32.5302 44.5305 36.1168 42.134C39.7033 39.7375 42.4987 36.3314 44.1494 32.3462C45.8002 28.361 46.2321 23.9758 45.3905 19.7452C44.549 15.5145 42.4718 11.6284 39.4217 8.57829L24 24L8.57829 8.57829Z"
                                        fill="currentColor"></path>
                                </g>
                                <defs>
                                    <clipPath id="clip0_6_319">
                                        <rect fill="white" height="48" width="48"></rect>
                                    </clipPath>
                                </defs>
                            </svg>
                        </div>
                        <div class="flex flex-col">
                            <h1 class="text-slate-900 dark:text-white text-base font-bold leading-none">KampusLegacy
                            </h1>
                            <p class="text-slate-500 dark:text-slate-400 text-xs font-medium mt-1">Mentor Portal</p>
                        </div>
                    </a>
                    <nav class="flex flex-col gap-1">
                        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-primary/10 text-primary font-medium transition-colors"
                            href="/mentor/home">
                            <span class="material-symbols-outlined text-[20px]">home</span>
                            <span class="text-sm">Home</span>
                        </a>
                        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-slate-200 transition-colors"
                            href="/mentor/dashboard">
                            <span class="material-symbols-outlined text-[20px]">dashboard</span>
                            <span class="text-sm">Dashboard</span>
                        </a>
                        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-slate-200 transition-colors"
                            href="/mentor/requests">
                            <span class="material-symbols-outlined text-[20px]">group</span>
                            <span class="text-sm">My Mentees</span>
                        </a>
                        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-slate-200 transition-colors"
                            href="/mentor/events">
                            <span class="material-symbols-outlined text-[20px]">event</span>
                            <span class="text-sm">Events</span>
                        </a>
                        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-slate-200 transition-colors"
                            href="/mentor/opportunities">
                            <span class="material-symbols-outlined text-[20px]">work</span>
                            <span class="text-sm">Opportunities</span>
                        </a>
                        <!-- <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-slate-200 transition-colors"
                            href="#">
                            <span class="material-symbols-outlined text-[20px]">calendar_month</span>
                            <span class="text-sm">Schedule</span>
                        </a> -->
                        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-slate-200 transition-colors"
                            href="/mentor/messages">
                            <span class="material-symbols-outlined text-[20px]">chat_bubble</span>
                            <span class="text-sm">Messages</span>
                        </a>
                        <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-slate-200 transition-colors"
                            href="/mentor/resources">
                            <span class="material-symbols-outlined text-[20px]">menu_book</span>
                            <span class="text-sm">Resources</span>
                        </a>
                    </nav>
                </div>
                <div class="p-6 border-t border-slate-200 dark:border-slate-800 mt-auto">
                    <div
                        class="flex items-center gap-3 p-2 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors cursor-pointer">
                        <div
                            class="h-9 w-9 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">
                            <%= user.name.charAt(0).toUpperCase() %>
                        </div>
                        <div class="flex flex-col min-w-0">
                            <p class="text-sm font-medium text-slate-900 dark:text-white truncate">
                                <%= user.name %>
                            </p>
                            <p class="text-xs text-slate-500 dark:text-slate-400 truncate">Mentor</p>
                        </div>
                    </div>
                    <a href="/auth/logout"
                        class="mt-2 flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:text-red-600 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/10 transition-colors text-sm font-medium">
                        <span class="material-symbols-outlined">logout</span>
                        Log Out
                    </a>
                </div>
            </div>
        </aside>
        <!-- Main Content -->
        <main class="flex-1 flex flex-col h-full overflow-hidden relative">
            <!-- Header -->
            <header
                class="h-16 flex items-center justify-between px-8 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 shrink-0 z-10">
                <h2 class="text-lg font-bold text-slate-900 dark:text-white">Home</h2>
                <div class="flex items-center gap-6">
                    <!-- <div class="relative w-80">
                        <span
                            class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">search</span>
                        <input
                            class="w-full pl-10 pr-4 py-2 bg-slate-100 dark:bg-slate-800 border-none rounded-lg text-sm text-slate-900 dark:text-white placeholder-slate-500 focus:ring-2 focus:ring-primary focus:bg-white dark:focus:bg-slate-900 transition-all"
                            placeholder="Search mentees, resources..." type="text" />
                    </div> -->
                    <div class="flex items-center gap-3 border-l border-slate-200 dark:border-slate-700 pl-6">
                        <button
                            class="relative p-2 text-slate-500 hover:text-primary dark:text-slate-400 dark:hover:text-primary transition-colors rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800">
                            <span class="material-symbols-outlined">notifications</span>
                            <span
                                class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full border-2 border-white dark:border-slate-900"></span>
                        </button>
                        <button
                            class="p-2 text-slate-500 hover:text-primary dark:text-slate-400 dark:hover:text-primary transition-colors rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800">
                            <span class="material-symbols-outlined">help</span>
                        </button>
                    </div>
                </div>
            </header>
            <!-- Scrollable Content -->
            <div class="flex-1 overflow-y-auto p-8 scrollbar-hide">
                <div class="max-w-7xl mx-auto space-y-8">
                    <!-- Welcome & Stats Row -->
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                        <!-- Welcome Section -->
                        <div class="lg:col-span-2 space-y-2">
                            <h1 class="text-3xl font-bold text-slate-900 dark:text-white tracking-tight">Welcome back,
                                <%= user.name.split(' ')[0] %></h1>
                            <p class="text-slate-500 dark:text-slate-400">Here' s what's happening in the KampusLegacy
                                    community today.</p>
                        </div>
                        <!-- Stats Cards -->
                        <div class="lg:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div
                                class="bg-white dark:bg-slate-900 p-5 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col justify-between h-32 relative overflow-hidden group">
                                <div
                                    class="absolute right-0 top-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                                    <span class="material-symbols-outlined text-6xl text-primary">event</span>
                                </div>
                                <p class="text-sm font-medium text-slate-500 dark:text-slate-400 z-10">Total Events Hosted
                                    </p>
                                <div class="flex items-end gap-2 z-10">
                                    <span class="text-3xl font-bold text-slate-900 dark:text-white"><%= stats.totalEventsPosted %></span>
                                </div>
                            </div>
                            <div
                                class="bg-white dark:bg-slate-900 p-5 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col justify-between h-32 relative overflow-hidden group">
                                <div
                                    class="absolute right-0 top-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                                    <span class="material-symbols-outlined text-6xl text-primary">group</span>
                                </div>
                                <p class="text-sm font-medium text-slate-500 dark:text-slate-400 z-10">Active Mentees
                                </p>
                                <div class="flex items-end gap-2 z-10">
                                    <span class="text-3xl font-bold text-slate-900 dark:text-white"><%= stats.activeMentees %></span>
                                    <% if (stats.newMenteesToday > 0) { %>
                                    <span
                                        class="text-xs font-medium text-green-600 bg-green-50 dark:bg-green-900/30 px-1.5 py-0.5 rounded mb-1 flex items-center">
                                        <span class="material-symbols-outlined text-[14px] mr-0.5">add</span>
                                        <%= stats.newMenteesToday %> New
                                    </span>
                                    <% } %>
                                </div>
                            </div>
                            <div
                                class="bg-white dark:bg-slate-900 p-5 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col justify-between h-32 relative overflow-hidden group">
                                <div
                                    class="absolute right-0 top-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                                    <span class="material-symbols-outlined text-6xl text-primary">calendar_clock</span>
                                </div>
                                <p class="text-sm font-medium text-slate-500 dark:text-slate-400 z-10">Upcoming Sessions
                                </p>
                                <div class="flex items-end gap-2 z-10">
                                    <span class="text-3xl font-bold text-slate-900 dark:text-white"><%= stats.upcomingSessionsCount %></span>
                                    <span
                                        class="text-xs font-medium text-slate-500 bg-slate-100 dark:bg-slate-800 px-1.5 py-0.5 rounded mb-1">Next 7 days</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Main Grid Layout -->
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                        <!-- Left Column: Action Items & Admin -->
                        <div class="lg:col-span-2 space-y-8">
                            <!-- Action Required -->
                            <% if (actionRequired.pendingRequestsCount > 0 || actionRequired.urgentEvents.length > 0) { %>
                            <div
                                class="bg-white dark:bg-slate-900 rounded-xl border border-red-100 dark:border-red-900/30 shadow-sm overflow-hidden">
                                <div
                                    class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between bg-red-50/50 dark:bg-red-900/10">
                                    <div class="flex items-center gap-2">
                                        <span
                                            class="material-symbols-outlined text-red-600 dark:text-red-400">priority_high</span>
                                        <h3 class="font-semibold text-slate-900 dark:text-white">Action Required</h3>
                                    </div>
                                    <span
                                        class="text-xs font-medium bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 px-2 py-1 rounded border border-slate-200 dark:border-slate-700">
                                        <%= actionRequired.pendingRequestsCount + actionRequired.urgentEvents.length %> Pending</span>
                                </div>
                                <div class="divide-y divide-slate-100 dark:divide-slate-800">
                                    <% actionRequired.urgentEvents.forEach(evt => { %>
                                    <div class="p-5 flex items-start sm:items-center gap-4 flex-col sm:flex-row">
                                        <div class="h-12 w-12 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center text-red-600">
                                            <span class="material-symbols-outlined">event_available</span>
                                        </div>
                                        <div class="flex-1">
                                            <p class="font-medium text-slate-900 dark:text-white">Upcoming: <%= evt.title %></p>
                                            <p
                                                class="text-sm text-slate-500 dark:text-slate-400 flex items-center gap-1 mt-0.5">
                                                <span class="material-symbols-outlined text-[16px]">schedule</span>
                                                Today at <%= evt.time %> • <%= evt.mode === 'online' ? 'Online' : evt.location %>
                                            </p>
                                        </div>
                                        <a href="/mentor/events/<%= evt._id %>"
                                            class="w-full sm:w-auto px-4 py-2 bg-primary hover:bg-primary-dark text-white rounded-lg text-sm font-medium transition-colors shadow-sm shadow-blue-500/20 text-center">
                                            View Event
                                        </a>
                                    </div>
                                    <% }) %>

                                    <% if (actionRequired.pendingRequestsCount > 0) { %>
                                    <div class="p-5 flex items-start sm:items-center gap-4 flex-col sm:flex-row">
                                        <div
                                            class="h-12 w-12 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-500 dark:text-slate-400">
                                            <span class="material-symbols-outlined">person_add</span>
                                        </div>
                                        <div class="flex-1">
                                            <p class="font-medium text-slate-900 dark:text-white">Mentorship Requests</p>
                                            <p class="text-sm text-slate-500 dark:text-slate-400 mt-0.5">You have <%= actionRequired.pendingRequestsCount %> pending requests. Accept to get connected.</p>
                                        </div>
                                        <div class="flex gap-2 w-full sm:w-auto">
                                            <a href="/mentor/requests"
                                                class="flex-1 sm:flex-none px-4 py-2 bg-primary/10 hover:bg-primary/20 text-primary rounded-lg text-sm font-medium transition-colors text-center">
                                                My Mentees
                                            </a>
                                        </div>
                                    </div>
                                    <% } %>
                                </div>
                            </div>
                            <% } %>
                            <!-- Community Feed -->
                            <div>
                                <div class="flex items-center justify-between mb-4">
                                    <h3 class="text-lg font-bold text-slate-900 dark:text-white">Community Highlights
                                    </h3>
                                    <div class="flex gap-2">
                                        <span
                                            class="px-2 py-1 text-xs font-medium text-slate-500 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded cursor-pointer hover:border-primary hover:text-primary transition-colors">All</span>
                                        <span
                                            class="px-2 py-1 text-xs font-medium text-slate-500 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded cursor-pointer hover:border-primary hover:text-primary transition-colors">Spotlights</span>
                                        <span
                                            class="px-2 py-1 text-xs font-medium text-slate-500 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded cursor-pointer hover:border-primary hover:text-primary transition-colors">Events</span>
                                    </div>
                                </div>
                                <div class="space-y-4">
                                    <!-- Spotlight Card -->
                                    <div
                                        class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-5 shadow-sm hover:shadow-md transition-shadow">
                                        <div class="flex justify-between items-start mb-3">
                                            <span
                                                class="px-2.5 py-1 rounded-full text-xs font-semibold bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300 flex items-center gap-1">
                                                <span class="material-symbols-outlined text-[14px]">star</span>
                                                Spotlight
                                            </span>
                                            <span class="text-xs text-slate-400">2 hours ago</span>
                                        </div>
                                        <div class="flex gap-4">
                                            <img alt="Students collaborating"
                                                class="w-24 h-24 rounded-lg object-cover flex-shrink-0 hidden sm:block"
                                                data-alt="Group of diverse people working together on laptops"
                                                src="https://lh3.googleusercontent.com/aida-public/AB6AXuCBpZX4VWOsrm2mbG8rTkNFaTCSKil22fq8ov5vMhjk1XpfQl-J8SsyMpuwuAORNVGSu_Jmaz3UT3RxIcUNTiaAGB2ExSIH_hExL3m0F7Tm4261G-TN7x7JKb_QIzwePd-6m7O0CLCHXNSq7uxYQUFRtCTAewCxlytMApB_Yt69yd1LCfHXPceElEwJG1eQhuvyelE_sJa2ouH3V2WtVMLRN3K9HjdIHaqAkonYXKywyvjIzrFRgfZf6EUse0uiYckgREvQafgj5lY" />
                                            <div>
                                                <h4 class="text-lg font-semibold text-slate-900 dark:text-white mb-1">
                                                    From Mentee to Google Engineer: David's Journey</h4>
                                                <p class="text-sm text-slate-600 dark:text-slate-400 mb-3 line-clamp-2">
                                                    Discover how regular mentorship sessions helped David navigate the
                                                    technical interview process and land his dream role.</p>
                                                <a class="text-primary text-sm font-medium hover:underline flex items-center gap-1"
                                                    href="#">Read Story <span
                                                        class="material-symbols-outlined text-[16px]">arrow_forward</span></a>
                                            </div>
                                        </div>
                                    </div>
                                    <% highlights.forEach(item => { %>
                                        <% if (item.highlightType === 'event') { %>
                                        <!-- Event Card -->
                                        <div
                                            class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-5 shadow-sm hover:shadow-md transition-shadow">
                                            <div class="flex justify-between items-start mb-3">
                                                <span
                                                    class="px-2.5 py-1 rounded-full text-xs font-semibold bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-300 flex items-center gap-1">
                                                    <span class="material-symbols-outlined text-[14px]">event</span> Event
                                                </span>
                                                <span class="text-xs text-slate-400">By <%= item.author?.name || 'Mentor' %></span>
                                            </div>
                                            <div class="flex items-start gap-4">
                                                <div
                                                    class="flex-shrink-0 w-14 h-14 bg-orange-50 dark:bg-orange-900/20 rounded-lg flex flex-col items-center justify-center border border-orange-100 dark:border-orange-800 text-orange-700 dark:text-orange-400 overflow-hidden relative">
                                                    <% if (item.bannerImage) { %>
                                                        <img src="<%= item.bannerImage %>" class="absolute inset-0 w-full h-full object-cover">
                                                    <% } else { %>
                                                        <span class="material-symbols-outlined">event</span>
                                                    <% } %>
                                                </div>
                                                <div>
                                                    <h4 class="text-base font-semibold text-slate-900 dark:text-white mb-1">
                                                        <%= item.title %></h4>
                                                    <p class="text-sm text-slate-500 dark:text-slate-400 mb-2 truncate max-w-[200px] sm:max-w-xs"><%= item.description %></p>
                                                    <div
                                                        class="flex items-center gap-4 text-xs text-slate-500 dark:text-slate-400">
                                                        <span class="flex items-center gap-1"><span
                                                                class="material-symbols-outlined text-[14px]"><%= item.mode === 'online' ? 'videocam' : 'location_on' %></span>
                                                            <%= item.mode === 'online' ? 'Online' : item.location %></span>
                                                        <span class="flex items-center gap-1"><span
                                                                class="material-symbols-outlined text-[14px]">schedule</span>
                                                            <%= item.time %></span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <% } else { %>
                                        <!-- Job Market Teaser -->
                                        <div onclick="openMentorOpportunitiesModal('<%= item.author?._id %>', '<%= item.author?.name %>')"
                                            class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-5 shadow-sm hover:shadow-md transition-all cursor-pointer group">
                                            <div class="flex justify-between items-start mb-3">
                                                <span
                                                    class="px-2.5 py-1 rounded-full text-xs font-semibold bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300 flex items-center gap-1">
                                                    <span class="material-symbols-outlined text-[14px]">work</span> Opportunity
                                                </span>
                                                <span class="text-xs text-slate-400 flex items-center gap-1 group-hover:text-primary transition-colors">By <%= item.author?.name || 'Mentor' %> <span class="material-symbols-outlined text-[16px]">open_in_new</span></span>
                                            </div>
                                            <div class="flex flex-col gap-2">
                                                <h4 class="text-base font-medium text-slate-900 dark:text-white"><%= item.title %> at <%= item.company %></h4>
                                                <p class="text-sm text-slate-500 dark:text-slate-400 mt-1"><span class="material-symbols-outlined text-[14px] align-middle mr-1">location_on</span> <%= item.location %></p>
                                            </div>
                                        </div>
                                        <% } %>
                                    <% }) %>
                                </div>
                            </div>
                        </div>
                        <!-- Right Column: Sidebar Widgets -->
                        <div class="space-y-6">
                            <!-- Announcement Banner -->
                            <div
                                class="bg-gradient-to-br from-indigo-600 to-primary rounded-xl p-5 text-white shadow-lg relative overflow-hidden">
                                <div
                                    class="absolute top-0 right-0 -mt-2 -mr-2 w-20 h-20 bg-white opacity-10 rounded-full blur-xl">
                                </div>
                                <div class="relative z-10">
                                    <div class="flex items-center gap-2 mb-2 opacity-90">
                                        <span class="material-symbols-outlined text-sm">campaign</span>
                                        <span class="text-xs font-bold uppercase tracking-wide">Admin Notice</span>
                                    </div>
                                    <h3 class="font-bold text-lg mb-2">Q4 Mentorship Survey</h3>
                                    <p class="text-sm text-blue-100 mb-4 leading-relaxed">Please complete the feedback
                                        survey to help us improve the platform for next semester.</p>
                                    <button
                                        class="w-full py-2 bg-white text-primary rounded-lg text-sm font-bold hover:bg-blue-50 transition-colors shadow-sm">
                                        Take Survey
                                    </button>
                                </div>
                            </div>
                            <!-- Mini Calendar / Upcoming -->
                            <div
                                class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-5">
                                <h3 class="font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-primary">calendar_month</span>
                                    Schedule
                                </h3>
                                <div class="space-y-4">
                                    <% if (upcomingEvents.length === 0) { %>
                                        <p class="text-sm text-slate-500">No upcoming events scheduled.</p>
                                    <% } %>
                                    <% upcomingEvents.forEach((evt, idx) => { %>
                                    <div
                                        class="flex gap-3 relative pb-4 border-l-2 border-slate-100 dark:border-slate-800 pl-4 last:border-0 last:pb-0">
                                        <div
                                            class="absolute -left-[5px] top-1.5 w-2.5 h-2.5 rounded-full <%= idx === 0 ? 'bg-primary ring-4 ring-white dark:ring-slate-900' : 'bg-slate-300 dark:bg-slate-600 ring-4 ring-white dark:ring-slate-900' %>">
                                        </div>
                                        <div class="flex-1 cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-800 p-2 rounded-lg -mt-2 transition-colors" onclick="window.location.href='/mentor/events/<%= evt._id %>'">
                                            <p class="text-xs font-semibold <%= idx === 0 ? 'text-primary' : 'text-slate-500' %> mb-0.5">
                                                <%= new Date(evt.date).toLocaleDateString() %>, <%= evt.time %>
                                            </p>
                                            <p class="text-sm font-medium text-slate-900 dark:text-white"><%= evt.title %></p>
                                            <p class="text-xs text-slate-500 mt-1"><%= evt.mode === 'online' ? 'Online' : evt.location %></p>
                                        </div>
                                    </div>
                                    <% }) %>
                                </div>
                                <a href="/mentor/events"
                                    class="w-full mt-5 py-2 text-primary block text-center text-sm font-medium hover:bg-primary/5 rounded-lg transition-colors">
                                    View Full Calendar
                                </a>
                            </div>
                            <!-- Active Students List -->
                            <div
                                class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm p-5">
                                <div class="flex items-center justify-between mb-4">
                                    <h3 class="font-bold text-slate-900 dark:text-white">My Mentees</h3>
                                    <button class="text-xs text-primary font-medium hover:underline">View All</button>
                                </div>
                                <div class="space-y-3">
                                    <% if (recentMentees.length === 0) { %>
                                        <p class="text-sm text-slate-500 text-center py-4">No active mentees yet.</p>
                                    <% } %>
                                    <% recentMentees.forEach(conn => { %>
                                        <% const stu = conn.student %>
                                    <div class="flex items-center gap-3 group">
                                        <div class="relative">
                                            <div
                                                class="w-9 h-9 rounded-full bg-indigo-100 text-indigo-600 dark:bg-indigo-900/30 dark:text-indigo-300 flex items-center justify-center text-xs font-bold border border-indigo-200 dark:border-indigo-800">
                                                <%= stu.name ? stu.name.substring(0,2).toUpperCase() : 'ST' %>
                                            </div>
                                            <% if (new Date(conn.updatedAt).toDateString() === new Date().toDateString()) { %>
                                            <span
                                                class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-white dark:border-slate-900 rounded-full"></span>
                                            <% } %>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-medium text-slate-900 dark:text-white truncate"><%= stu.name %></p>
                                            <p class="text-xs text-slate-500 truncate"><%= stu.institution || 'Student' %></p>
                                        </div>
                                    </div>
                                    <% }) %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Mentor Opportunities Modal -->
    <div id="mentor-opportunities-modal"
        class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
        <div
            class="bg-white dark:bg-slate-900 w-full max-w-3xl rounded-2xl shadow-xl overflow-hidden transform scale-95 transition-transform duration-300">
            <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex justify-between items-center bg-slate-50 dark:bg-slate-800/50">
                <h3 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-[20px]">work</span>
                    Opportunities by <span id="modal-mentor-name" class="text-primary font-bold ml-1">...</span>
                </h3>
                <button onclick="closeMentorOpportunitiesModal()"
                    class="text-slate-400 hover:text-slate-600 dark:hover:text-white transition-colors p-1 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-700">
                    <span class="material-symbols-outlined text-[20px]">close</span>
                </button>
            </div>
            <div class="max-h-[60vh] overflow-y-auto p-6 scrollbar-thin">
                <div id="modal-opportunities-list" class="space-y-4">
                    <!-- Opportunities will be injected here via Fetch -->
                    <div class="flex justify-center py-8">
                        <span class="material-symbols-outlined animate-spin text-primary text-3xl">autorenew</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Modal functionality for Mentor Highlights
        const modal = document.getElementById('mentor-opportunities-modal');
        const listContainer = document.getElementById('modal-opportunities-list');
        const nameSpan = document.getElementById('modal-mentor-name');
        
        async function openMentorOpportunitiesModal(authorId, authorName) {
            nameSpan.textContent = authorName;
            listContainer.innerHTML = '<div class="flex justify-center py-8"><span class="material-symbols-outlined animate-spin text-primary text-3xl">autorenew</span></div>';
            
            // Show modal
            modal.classList.remove('opacity-0', 'pointer-events-none');
            modal.firstElementChild.classList.remove('scale-95');
            modal.firstElementChild.classList.add('scale-100');
            
            try {
                const response = await fetch(`/mentor/api/opportunities/author/${authorId}`);
                const data = await response.json();
                
                if (data.success) {
                    if (data.opportunities.length === 0) {
                        listContainer.innerHTML = '<p class="text-slate-500 text-center py-4">No public opportunities found.</p>';
                    } else {
                        listContainer.innerHTML = data.opportunities.map(opp => `
                            <div class="bg-slate-50 dark:bg-slate-800/50 rounded-xl p-4 border border-slate-200 dark:border-slate-700">
                                <div class="flex justify-between items-start mb-2">
                                    <h4 class="font-bold text-slate-900 dark:text-white">${opp.title}</h4>
                                    <span class="text-xs font-semibold px-2 py-1 rounded bg-slate-200 dark:bg-slate-700 text-slate-600 dark:text-slate-300">${opp.type || 'Job'}</span>
                                </div>
                                <p class="text-sm text-slate-700 dark:text-slate-300 font-medium mb-1">${opp.company}</p>
                                <div class="flex items-center gap-4 text-xs text-slate-500 mt-2">
                                    <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">location_on</span> ${opp.location}</span>
                                    <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">payments</span> ${opp.salary || 'Unpaid'}</span>
                                </div>
                            </div>
                        `).join('');
                    }
                } else {
                    throw new Error('Failed to fetch data');
                }
            } catch (err) {
                console.error(err);
                listContainer.innerHTML = '<p class="text-red-500 text-center py-4">Could not load opportunities at this time.</p>';
            }
        }
        
        function closeMentorOpportunitiesModal() {
            modal.classList.add('opacity-0', 'pointer-events-none');
            modal.firstElementChild.classList.remove('scale-100');
            modal.firstElementChild.classList.add('scale-95');
        }
    </script>
</body>
</html>