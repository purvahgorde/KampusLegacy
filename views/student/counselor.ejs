<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>AI Career Counselor - KampusLegacy</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: { "primary": "#135bec", "primary-light": "#e8effd", "background-light": "#f6f6f8", "background-dark": "#101622" },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                },
            },
        }
    </script>
    <style>
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
        .chat-container { height: calc(100vh - 180px); }
        .message-bubble { max-width: 80%; }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased overflow-hidden">
    <div class="flex h-screen w-full">

        <!-- Sidebar Navigation -->
        <aside class="hidden md:flex flex-col w-64 h-full bg-white dark:bg-[#1a2332] border-r border-slate-200 dark:border-slate-800 flex-shrink-0 z-20">
            <a href="/" class="flex items-center gap-3 px-6 py-8">
                <div class="h-8 w-8 text-primary">
                    <svg class="h-full w-full" fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                        <path d="M8.57829 8.57829C5.52816 11.6284 3.451 15.5145 2.60947 19.7452C1.76794 23.9758 2.19984 28.361 3.85056 32.3462C5.50128 36.3314 8.29667 39.7376 11.8832 42.134C15.4698 44.5305 19.6865 45.8096 24 45.8096C28.3135 45.8096 32.5302 44.5305 36.1168 42.134C39.7033 39.7375 42.4987 36.3314 44.1494 32.3462C45.8002 28.361 46.2321 23.9758 45.3905 19.7452C44.549 15.5145 42.4718 11.6284 39.4217 8.57829L24 24L8.57829 8.57829Z" fill="currentColor"></path>
                    </svg>
                </div>
                <h1 class="text-xl font-bold tracking-tight text-slate-900 dark:text-white">KampusLegacy</h1>
            </a>
            <div class="flex flex-col gap-1 px-4 flex-1 overflow-y-auto">
                <nav class="space-y-1">
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium" href="/student/home">
                        <span class="material-symbols-outlined">home</span>Home
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium" href="/student/dashboard">
                        <span class="material-symbols-outlined">dashboard</span>Dashboard
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium" href="/student/mentors">
                        <span class="material-symbols-outlined">group</span>Mentors
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium" href="/student/opportunities">
                        <span class="material-symbols-outlined">work</span>Jobs & Internships
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium" href="/student/events">
                        <span class="material-symbols-outlined">event</span>Events
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium" href="/student/resources">
                        <span class="material-symbols-outlined">folder_open</span>Resources
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-primary/10 text-primary font-medium transition-colors" href="/student/counselor">
                        <span class="material-symbols-outlined">smart_toy</span>AI Counselor
                    </a>
                </nav>
            </div>
            <div class="p-4 mt-auto">
                <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:text-red-600 transition-colors text-sm font-medium" href="/auth/logout">
                    <span class="material-symbols-outlined">logout</span>Log Out
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col h-full bg-background-light dark:bg-background-dark">
            <header class="h-16 flex items-center px-6 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 shrink-0">
                <div class="flex items-center gap-3">
                    <div class="h-8 w-8 rounded-full bg-primary/20 text-primary flex items-center justify-center">
                        <span class="material-symbols-outlined text-lg">smart_toy</span>
                    </div>
                    <div>
                        <h2 class="text-sm font-bold text-slate-900 dark:text-white leading-none">AI Career Counselor</h2>
                        <p class="text-[10px] text-green-500 font-medium mt-1 uppercase tracking-wider flex items-center gap-1">
                            <span class="h-1 w-1 bg-green-500 rounded-full animate-pulse"></span> Online
                        </p>
                    </div>
                </div>
            </header>

            <div class="flex-1 overflow-y-auto p-6 scroll-smooth chat-container" id="chat-messages">
                <% if (chatHistory.length === 0) { %>
                    <div class="h-full flex flex-col items-center justify-center text-center max-w-md mx-auto">
                        <div class="h-16 w-16 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-4">
                            <span class="material-symbols-outlined text-3xl">psychology</span>
                        </div>
                        <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Your Career Journey Starts Here</h3>
                        <p class="text-sm text-slate-500 mb-6">Ask about internships, resumes, skill building, or any career guidance you need.</p>
                        <div class="grid grid-cols-2 gap-3 w-full">
                            <button onclick="presetMsg('How should I structure my tech resume?')" class="p-3 text-xs text-left bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl hover:border-primary transition-colors">
                                Resume Structure 📄
                            </button>
                            <button onclick="presetMsg('How to find frontend internships?')" class="p-3 text-xs text-left bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl hover:border-primary transition-colors">
                                Find Internships 🔍
                            </button>
                        </div>
                    </div>
                <% } else { %>
                    <% chatHistory.forEach(msg => { %>
                        <div class="flex <%= msg.role === 'user' ? 'justify-end' : 'justify-start' %> mb-6">
                            <div class="message-bubble <%= msg.role === 'user' ? 'bg-primary text-white rounded-t-2xl rounded-bl-2xl shadow-lg shadow-primary/20' : 'bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-200 rounded-t-2xl rounded-br-2xl border border-slate-200 dark:border-slate-700' %> p-4">
                                <p class="text-sm whitespace-pre-wrap leading-relaxed"><%= msg.text %></p>
                                <span class="block text-[10px] mt-2 opacity-60 text-right"><%= new Date(msg.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %></span>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>

            <div class="p-6 bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800">
                <form id="chat-form" class="max-w-4xl mx-auto flex items-end gap-3">
                    <div class="flex-1 relative">
                        <textarea id="message-input" rows="1" placeholder="Type your message..." class="w-full pl-4 pr-12 py-3 bg-slate-50 dark:bg-slate-800 border-none rounded-2xl focus:ring-2 focus:ring-primary/20 text-sm resize-none scrollbar-hide" required></textarea>
                    </div>
                    <button type="submit" id="send-btn" class="h-11 w-11 flex items-center justify-center bg-primary text-white rounded-2xl hover:bg-primary/90 transition-all shadow-lg shadow-primary/20 shrink-0">
                        <span class="material-symbols-outlined">send</span>
                    </button>
                </form>
            </div>
        </main>
    </div>

    <script>
        const chatForm = document.getElementById('chat-form');
        const chatMessages = document.getElementById('chat-messages');
        const messageInput = document.getElementById('message-input');
        const sendBtn = document.getElementById('send-btn');

        function scrollToBottom() {
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }
        scrollToBottom();

        function presetMsg(text) {
            messageInput.value = text;
            chatForm.dispatchEvent(new Event('submit'));
        }

        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const msg = messageInput.value.trim();
            if (!msg) return;

            // Add user message to UI
            addMessage(msg, 'user');
            messageInput.value = '';
            messageInput.style.height = 'auto';
            
            // Loading state
            sendBtn.disabled = true;
            sendBtn.innerHTML = '<span class="material-symbols-outlined animate-spin">refresh</span>';
            const loadingBubble = addMessage('Thinking...', 'model', true);

            try {
                const res = await fetch('/student/counselor/message', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: msg })
                });
                const data = await res.json();
                
                if (data.success) {
                    loadingBubble.remove();
                    addMessage(data.response, 'model');
                } else {
                    throw new Error(data.error);
                }
            } catch (err) {
                loadingBubble.innerHTML = `<p class="text-sm text-red-500">Error: Could not connect to AI.</p>`;
            } finally {
                sendBtn.disabled = false;
                sendBtn.innerHTML = '<span class="material-symbols-outlined">send</span>';
            }
        });

        function addMessage(text, role, isLoading = false) {
            const div = document.createElement('div');
            div.className = `flex ${role === 'user' ? 'justify-end' : 'justify-start'} mb-6 animate-in slide-in-from-bottom-2 duration-300`;
            
            const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            
            div.innerHTML = `
                <div class="message-bubble ${role === 'user' ? 'bg-primary text-white rounded-t-2xl rounded-bl-2xl shadow-lg shadow-primary/20' : 'bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-200 rounded-t-2xl rounded-br-2xl border border-slate-200 dark:border-slate-700'} p-4">
                    <p class="text-sm whitespace-pre-wrap leading-relaxed">${text}</p>
                    <span class="block text-[10px] mt-2 opacity-60 text-right">${time}</span>
                </div>
            `;
            
            chatMessages.appendChild(div);
            scrollToBottom();
            return div;
        }

        // Auto-expand textarea
        messageInput.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';
        });
    </script>
</body>
</html>
