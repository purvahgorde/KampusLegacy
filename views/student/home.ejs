<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>KampusLegacy - Student Hub</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#135bec",
                        "primary-light": "#eef4ff", // Very light blue for backgrounds
                        "background-light": "#f6f6f8",
                        "background-dark": "#101622",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"],
                        "sans": ["Inter", "sans-serif"],
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "2xl": "1rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        /* Custom scrollbar for horizontal scrolling sections */
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display antialiased">
    <div class="flex h-screen w-full overflow-hidden">
        <!-- Sidebar Navigation -->
        <aside
            class="hidden md:flex flex-col w-64 h-full bg-white dark:bg-[#1a2332] border-r border-slate-200 dark:border-slate-800 flex-shrink-0 z-20">
            <a href="/" class="flex items-center gap-3 px-6 py-8">
                <div class="h-8 w-8 text-primary">
                    <svg class="h-full w-full" fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                        <g clip-path="url(#clip0_6_319)">
                            <path
                                d="M8.57829 8.57829C5.52816 11.6284 3.451 15.5145 2.60947 19.7452C1.76794 23.9758 2.19984 28.361 3.85056 32.3462C5.50128 36.3314 8.29667 39.7376 11.8832 42.134C15.4698 44.5305 19.6865 45.8096 24 45.8096C28.3135 45.8096 32.5302 44.5305 36.1168 42.134C39.7033 39.7375 42.4987 36.3314 44.1494 32.3462C45.8002 28.361 46.2321 23.9758 45.3905 19.7452C44.549 15.5145 42.4718 11.6284 39.4217 8.57829L24 24L8.57829 8.57829Z"
                                fill="currentColor"></path>
                        </g>
                        <defs>
                            <clipPath id="clip0_6_319">
                                <rect fill="white" height="48" width="48"></rect>
                            </clipPath>
                        </defs>
                    </svg>
                </div>
                <h1 class="text-xl font-bold tracking-tight text-slate-900 dark:text-white">KampusLegacy</h1>
            </a>
            <div class="flex flex-col gap-1 px-4 flex-1 overflow-y-auto">
                <!-- User Profile Summary -->
                <div
                    class="mb-6 p-4 rounded-xl bg-primary-light/50 dark:bg-slate-800/50 border border-primary/10 dark:border-slate-700 cursor-pointer hover:shadow-md hover:border-primary/20 transition-all group"
                    onclick="openProfilePopup()">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-primary font-bold text-base border-2 border-white dark:border-slate-600 flex-shrink-0 group-hover:scale-110 transition-transform">
                            <%= user.name.charAt(0).toUpperCase() %>
                        </div>
                        <div class="overflow-hidden flex-1">
                            <h3 class="text-sm font-semibold truncate text-slate-900 dark:text-white">
                                <%= user.name %>
                            </h3>
                            <p class="text-xs text-slate-500 dark:text-slate-400 truncate flex items-center gap-1">
                                <span class="material-symbols-outlined text-xs">edit</span>View Profile
                            </p>
                        </div>
                    </div>
                </div>
                <!-- Nav Links -->
                <nav class="space-y-1">
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-primary/10 text-primary font-medium"
                        href="/student/home">
                        <span class="material-symbols-outlined fill-1">home</span>
                        Home
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium"
                        href="/student/dashboard">
                        <span class="material-symbols-outlined">message</span>
                        Messages
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium"
                        href="/student/mentors">
                        <span class="material-symbols-outlined">group</span>
                        Mentors
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium"
                        href="/student/opportunities">
                        <span class="material-symbols-outlined">work</span>
                        Jobs &amp; Internships
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium"
                        href="/student/events">
                        <span class="material-symbols-outlined">event</span>
                        Events
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium"
                        href="/student/resources">
                        <span class="material-symbols-outlined">folder_open</span>
                        Resources
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium"
                        href="/student/counselor">
                        <span class="material-symbols-outlined">smart_toy</span>
                        AI Counselor
                    </a>
                </nav>
            </div>
            <div class="p-4 mt-auto">
                <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors text-sm font-medium"
                    href="#">
                    <span class="material-symbols-outlined">settings</span>
                    Settings
                </a>
                <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:text-red-600 transition-colors text-sm font-medium"
                    href="/auth/logout">
                    <span class="material-symbols-outlined">logout</span>
                    Log Out
                </a>
            </div>
        </aside>
        <!-- Main Content -->
        <main class="flex-1 h-full overflow-y-auto overflow-x-hidden bg-background-light dark:bg-background-dark">
            <!-- Header Mobile/Desktop -->
            <header
                class="sticky top-0 z-10 bg-white/80 dark:bg-[#1a2332]/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800 px-6 py-4 flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <button class="md:hidden p-2 -ml-2 text-slate-500 hover:text-slate-700">
                        <span class="material-symbols-outlined">menu</span>
                    </button>
                    <div>
                        <h2 class="text-xl font-bold text-slate-900 dark:text-white">Welcome back, <%= user.name.split(' ')[0] %>! 👋</h2>
                        <p class="text-sm text-slate-500 dark:text-slate-400 hidden sm:block">Here' s what's happening
                                in your network today.</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <div class="relative hidden sm:block">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
                            <span class="material-symbols-outlined text-[20px]">search</span>
                        </span>
                        <input
                            class="w-64 pl-10 pr-4 py-2 bg-slate-100 dark:bg-slate-800 border-none rounded-lg text-sm text-slate-900 dark:text-white placeholder-slate-500 focus:ring-2 focus:ring-primary/50 focus:bg-white dark:focus:bg-slate-700 transition-all"
                            placeholder="Search mentors, jobs..." type="text" />
                    </div>
                    <button class="relative p-2 text-slate-500 hover:text-primary transition-colors">
                        <span class="material-symbols-outlined">notifications</span>
                        <span
                            class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full border border-white dark:border-slate-800"></span>
                    </button>
                </div>
            </header>
            <div class="p-6 max-w-7xl mx-auto space-y-8">
                <!-- Section 1: Mentors (Horizontal Scroll) -->
                <section>
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary">verified_user</span>
                            Available Mentors
                        </h3>
                        <a class="text-sm font-medium text-primary hover:text-primary/80 flex items-center gap-1"
                            href="/student/mentors">
                            View All <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                        </a>
                    </div>
                    <div class="flex gap-4 overflow-x-auto pb-4 hide-scrollbar snap-x">
                        <% if (mentors && mentors.length> 0) { %>
                            <% mentors.forEach(mentor=> { %>
                                <div
                                    class="min-w-[240px] bg-white dark:bg-[#1e293b] p-5 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm hover:shadow-md transition-shadow snap-start flex flex-col">
                                    <div class="flex flex-col items-center text-center w-full flex-1">
                                        <div class="relative mb-3">
                                            <% if (mentor.profilePicture) { %>
                                                <img alt="Portrait of <%= mentor.name %>"
                                                    class="w-20 h-20 rounded-full object-cover border-2 border-white dark:border-slate-600 shadow-sm"
                                                    src="<%= mentor.profilePicture %>" />
                                                <% } else { %>
                                                    <div
                                                        class="w-20 h-20 rounded-full bg-gradient-to-br from-primary/20 to-primary/40 flex items-center justify-center text-primary font-bold text-2xl shadow-sm border-2 border-white dark:border-slate-600">
                                                        <%= mentor.name.charAt(0).toUpperCase() %>
                                                    </div>
                                                    <% } %>
                                                        <div
                                                            class="absolute bottom-0 right-0 bg-green-500 w-4 h-4 rounded-full border-2 border-white dark:border-slate-800">
                                                        </div>
                                        </div>
                                        <h4 class="font-bold text-slate-900 dark:text-white truncate w-full px-2">
                                            <%= mentor.name %>
                                        </h4>
                                        <p class="text-xs text-primary font-medium mb-1 w-full line-clamp-2 px-2">
                                            <%= mentor.jobTitle || 'Mentor' %>
                                                <%= mentor.company ? ' @ ' + mentor.company : '' %>
                                        </p>
                                        <div
                                            class="flex gap-1 mt-2 mb-4 flex-wrap justify-center h-[24px] overflow-hidden">
                                            <% if (mentor.skills && mentor.skills.length> 0) { %>
                                                <% mentor.skills.slice(0, 2).forEach(skill=> { %>
                                                    <span
                                                        class="px-2 py-0.5 rounded text-[10px] font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300">
                                                        <%= skill %>
                                                    </span>
                                                    <% }) %>
                                                        <% } else if (mentor.domain) { %>
                                                            <span
                                                                class="px-2 py-0.5 rounded text-[10px] font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300">
                                                                <%= mentor.domain %>
                                                            </span>
                                                            <% } else { %>
                                                                <span
                                                                    class="px-2 py-0.5 rounded text-[10px] font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300">General</span>
                                                                <% } %>
                                        </div>
                                        <form method="POST" action="/student/connect/<%= mentor._id %>"
                                            class="w-full mt-auto">
                                            <button type="submit"
                                                class="w-full py-1.5 px-3 rounded-lg bg-primary text-white text-sm font-medium hover:bg-primary/90 transition-colors">Connect</button>
                                        </form>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } else { %>
                                        <div
                                            class="w-full py-8 flex flex-col items-center justify-center text-slate-500 dark:text-slate-400">
                                            <span
                                                class="material-symbols-outlined text-4xl mb-2 opacity-50">search_off</span>
                                            <p class="text-sm font-medium">No mentors available right now.</p>
                                        </div>
                                        <% } %>
                    </div>
                </section>

                <!-- AI Career Counselor Highlight Card -->
                <div class="mb-10 relative overflow-hidden rounded-3xl bg-slate-900 dark:bg-primary-light/5 p-8 text-white">
                    <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
                        <div class="max-w-xl">
                            <div class="flex items-center gap-2 mb-4">
                                <span class="px-3 py-1 rounded-full bg-primary/20 text-primary-light text-[10px] font-bold uppercase tracking-widest border border-primary/30">AI Insight</span>
                                <span class="h-1.5 w-1.5 rounded-full bg-green-400 animate-pulse"></span>
                                <span class="text-[10px] font-bold text-green-400 uppercase tracking-widest">Live Now</span>
                            </div>
                            <h2 class="text-3xl sm:text-4xl font-black mb-4 tracking-tight">Your AI Career <span class="text-primary-light">Counselor</span> 🤖</h2>
                            <p class="text-slate-400 text-sm sm:text-base mb-8 leading-relaxed">Stuck on your career path? Ask our advanced AI for curated advice on internships, resumes, and technical growth — personalized just for you.</p>
                            <a href="/student/counselor" class="inline-flex items-center gap-3 px-8 py-4 bg-primary hover:bg-primary/90 rounded-2xl font-bold transition-all hover:scale-[1.02] active:scale-95 shadow-2xl shadow-primary/40 group">
                                Start Your Journey 
                                <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
                            </a>
                        </div>
                        <div class="hidden lg:block relative">
                            <div class="absolute -inset-10 bg-primary/30 rounded-full blur-[80px] animate-pulse"></div>
                            <div class="relative h-48 w-48 rounded-3xl bg-white/5 backdrop-blur-sm border border-white/10 flex items-center justify-center rotate-3 group hover:rotate-0 transition-transform duration-500">
                                <span class="material-symbols-outlined text-[100px] text-primary-light opacity-80">psychology</span>
                            </div>
                        </div>
                    </div>
                    <!-- Abstract Background Decorations -->
                    <div class="absolute -top-24 -right-24 h-64 w-64 rounded-full bg-primary/20 blur-[100px]"></div>
                    <div class="absolute -bottom-24 -left-24 h-64 w-64 rounded-full bg-indigo-500/10 blur-[100px]"></div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    <!-- Left Column (Span 2) -->
                    <div class="lg:col-span-2 space-y-8">
                        <!-- Events & Hackathons -->
                        <section>
                            <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                                <span class="material-symbols-outlined text-purple-500">event</span>
                                Upcoming Events
                            </h3>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <% if (upcomingEvents && upcomingEvents.length> 0) { %>
                                    <% upcomingEvents.forEach(ev=> { %>
                                        <div
                                            class="group bg-white dark:bg-[#1e293b] rounded-xl border border-slate-200 dark:border-slate-700 overflow-hidden hover:shadow-md transition-all">
                                            <div class="h-32 w-full bg-cover bg-center relative"
                                                style="background-image: url('<%= ev.bannerImage %>');">
                                                <div
                                                    class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent">
                                                </div>
                                                <div class="absolute bottom-3 left-3 text-white">
                                                    <% let badgeBg='bg-primary' ; if (ev.eventType==='HACKATHON' )
                                                        badgeBg='bg-purple-600' ; if (ev.eventType==='WORKSHOP' )
                                                        badgeBg='bg-green-600' ; if (ev.eventType==='SEMINAR' )
                                                        badgeBg='bg-amber-600' ; if (ev.eventType==='NETWORKING' )
                                                        badgeBg='bg-sky-600' ; %>
                                                        <span
                                                            class="<%= badgeBg %> px-2 py-0.5 rounded text-xs font-bold uppercase tracking-wider">
                                                            <%= ev.eventType || 'Event' %>
                                                        </span>
                                                </div>
                                            </div>
                                            <div class="p-4">
                                                <div class="flex justify-between items-start mb-2">
                                                    <div>
                                                        <h4
                                                            class="font-bold text-slate-900 dark:text-white group-hover:text-primary transition-colors line-clamp-1">
                                                            <%= ev.title %>
                                                        </h4>
                                                        <p class="text-sm text-slate-500 dark:text-slate-400">
                                                            <%= new Date(ev.date).toLocaleDateString(undefined, {
                                                                month: 'short' , day: 'numeric' , year: 'numeric' }) %>
                                                                &bull; <%= ev.mode %>
                                                        </p>
                                                    </div>
                                                    <div
                                                        class="flex flex-col items-center bg-slate-100 dark:bg-slate-700 rounded-lg p-1.5 min-w-[50px]">
                                                        <span
                                                            class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase">
                                                            <%= new Date(ev.date).toLocaleString(undefined, {
                                                                month: 'short' }) %>
                                                        </span>
                                                        <span
                                                            class="text-lg font-bold text-slate-900 dark:text-white leading-none">
                                                            <%= new Date(ev.date).getDate() %>
                                                        </span>
                                                    </div>
                                                </div>
                                                <% if (ev.isRegistered) { %>
                                                    <button disabled
                                                        class="w-full mt-2 py-2 rounded-lg bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400 text-sm font-bold opacity-80 cursor-not-allowed">Registered</button>
                                                    <% } else if (ev.registrationMode==='external' ) { %>
                                                        <a href="<%= ev.externalLink %>" target="_blank"
                                                            class="block text-center w-full mt-2 py-2 rounded-lg border border-slate-200 dark:border-slate-600 text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">Register
                                                            Now</a>
                                                        <% } else { %>
                                                            <a href="/student/events?eventId=<%= ev._id %>"
                                                                class="block text-center w-full mt-2 py-2 rounded-lg border border-slate-200 dark:border-slate-600 text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">Register
                                                                Now</a>
                                                            <% } %>
                                            </div>
                                        </div>
                                        <% }); %>
                                            <% } else { %>
                                                <div
                                                    class="col-span-1 md:col-span-2 py-8 flex flex-col items-center justify-center text-slate-500 dark:text-slate-400 bg-slate-50 dark:bg-slate-800/30 rounded-xl border border-dashed border-slate-200 dark:border-slate-700">
                                                    <span
                                                        class="material-symbols-outlined text-3xl mb-1 opacity-50">event_busy</span>
                                                    <p class="text-sm">No upcoming events right now.</p>
                                                </div>
                                                <% } %>
                            </div>
                        </section>
                        <!-- Jobs & Internships -->
                        <section>
                            <div class="flex items-center justify-between mb-4">
                                <h3 class="text-lg font-bold text-slate-900 dark:text-white flex items-center gap-2">
                                    <span class="material-symbols-outlined text-orange-500">briefcase_meal</span>
                                    Fresh Opportunities
                                </h3>
                                <a class="text-sm font-medium text-slate-500 hover:text-primary transition-colors"
                                    href="/student/opportunities">View All Jobs</a>
                            </div>
                            <div
                                class="bg-white dark:bg-[#1e293b] rounded-xl border border-slate-200 dark:border-slate-700 divide-y divide-slate-100 dark:divide-slate-700">
                                <% if (freshOpportunities && freshOpportunities.length> 0) { %>
                                    <% freshOpportunities.forEach(opp=> { %>
                                        <div
                                            class="p-4 flex flex-col sm:flex-row sm:items-center gap-4 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                                            <div
                                                class="w-12 h-12 rounded-lg bg-slate-100 dark:bg-slate-800 flex items-center justify-center flex-shrink-0">
                                                <span
                                                    class="material-symbols-outlined text-2xl text-slate-600 dark:text-slate-400">
                                                    <%= opp.type==='Internship' ? 'deployed_code' : 'work' %>
                                                </span>
                                            </div>
                                            <div class="flex-1 min-w-0">
                                                <h4 class="font-semibold text-slate-900 dark:text-white truncate">
                                                    <%= opp.title %>
                                                </h4>
                                                <p
                                                    class="text-sm text-slate-500 dark:text-slate-400 flex items-center gap-2">
                                                    <span>
                                                        <%= opp.company %>
                                                    </span>
                                                    <span class="w-1 h-1 bg-slate-300 rounded-full"></span>
                                                    <span>
                                                        <%= opp.location || 'Remote' %>
                                                    </span>
                                                </p>
                                            </div>
                                            <div class="flex items-center gap-3">
                                                <% let typeColor=opp.type==='Internship'
                                                    ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400'
                                                    : 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400'
                                                    ; %>
                                                    <span
                                                        class="px-2.5 py-1 rounded-full <%= typeColor %> text-xs font-medium">
                                                        <%= opp.type %>
                                                    </span>
                                                    <a href="/student/opportunities?jobId=<%= opp._id %>"
                                                        class="px-4 py-2 rounded-lg bg-slate-900 dark:bg-white text-white dark:text-slate-900 text-sm font-medium hover:opacity-90 transition-opacity">Apply</a>
                                            </div>
                                        </div>
                                        <% }); %>
                                            <% } else { %>
                                                <div
                                                    class="p-8 flex items-center justify-center text-slate-500 dark:text-slate-400 bg-slate-50 dark:bg-slate-800/20 text-sm">
                                                    No recent opportunities available yet. Connect with mentors to see
                                                    jobs here.
                                                </div>
                                                <% } %>
                            </div>
                        </section>
                    </div>
                    <!-- Right Column (Span 1) -->
                    <div class="space-y-8">
                        <!-- Student Spotlight -->
                        <section
                            class="bg-gradient-to-br from-primary to-[#2563EB] rounded-2xl p-6 text-white relative overflow-hidden">
                            <div class="absolute top-0 right-0 p-4 opacity-10">
                                <span class="material-symbols-outlined text-[120px]">star</span>
                            </div>
                            <div class="relative z-10">
                                <div class="flex items-center justify-between mb-4">
                                    <h3 class="text-sm font-bold uppercase tracking-wider opacity-90">Student Spotlight
                                    </h3>
