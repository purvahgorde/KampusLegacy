<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>KampusLegacy - Student Dashboard</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#135bec",
                        "primary-content": "#ffffff",
                        "primary-dark": "#0e4bce",
                        "primary-light": "#e8effd",
                        "background-light": "#f6f6f8",
                        "background-dark": "#101622",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"],
                        "body": ["Inter", "sans-serif"],
                    },
                    borderRadius: {
                        "DEFAULT": "0.5rem",
                        "lg": "0.75rem",
                        "xl": "1rem",
                        "2xl": "1.5rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
    <style>
        /* Custom scrollbar for chat area */
        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }

        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background-color: #cbd5e1;
            border-radius: 20px;
        }

        .dark .custom-scrollbar::-webkit-scrollbar-thumb {
            background-color: #475569;
        }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display antialiased">
    <div class="flex h-screen w-full overflow-hidden">
        <!-- Sidebar Navigation -->
        <aside
            class="hidden md:flex flex-col w-64 h-full bg-white dark:bg-[#1a2332] border-r border-slate-200 dark:border-slate-800 flex-shrink-0 z-20">
            <a href="/" class="flex items-center gap-3 px-6 py-8">
                <div class="h-8 w-8 text-primary">
                    <svg class="h-full w-full" fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                        <g clip-path="url(#clip0_6_319)">
                            <path
                                d="M8.57829 8.57829C5.52816 11.6284 3.451 15.5145 2.60947 19.7452C1.76794 23.9758 2.19984 28.361 3.85056 32.3462C5.50128 36.3314 8.29667 39.7376 11.8832 42.134C15.4698 44.5305 19.6865 45.8096 24 45.8096C28.3135 45.8096 32.5302 44.5305 36.1168 42.134C39.7033 39.7375 42.4987 36.3314 44.1494 32.3462C45.8002 28.361 46.2321 23.9758 45.3905 19.7452C44.549 15.5145 42.4718 11.6284 39.4217 8.57829L24 24L8.57829 8.57829Z"
                                fill="currentColor"></path>
                        </g>
                        <defs>
                            <clipPath id="clip0_6_319">
                                <rect fill="white" height="48" width="48"></rect>
                            </clipPath>
                        </defs>
                    </svg>
                </div>
                <h1 class="text-xl font-bold text-slate-900 dark:text-white">KampusLegacy</h1>
            </a>
            <div class="flex flex-col gap-1 px-4 flex-1 overflow-y-auto">
                <!-- User Profile Summary -->
                <div
                    class="mb-6 p-4 rounded-xl bg-primary-light/50 dark:bg-slate-800/50 border border-primary/10 dark:border-slate-700">
                    <div class="flex items-center gap-3">
                        <img alt="Student profile photo"
                            class="h-10 w-10 rounded-full object-cover border-2 border-white dark:border-slate-600"
                            data-alt="Young asian female student portrait"
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDQld-yO7kAq_Jb0RKvWe9vAfYzh_9HSjL54Z1_JVHPcc3-zAEAd8CEtz5opMt-Y2QYj8fUvnFf0IxhqQwGqTu5Op36fXhNlcJECkc9Xq4kp8K9sV14S0YFsswuX8O24mXsMXOTwm9ECR0aG53HrG7ij1rSO6mc8Jz0-MNuesyy3Y2JtdSpyeUbTMf3R12lS1eQ4wxLTnSyvi0mvOlxy8EREIZOTVqZewbnLwgGnNnxkMHG0PmP7SyxYZRfeM1m03UEmkoGF47mVws" />
                        <div class="overflow-hidden">
                            <h3 class="text-sm font-semibold truncate text-slate-900 dark:text-white">
                                <%= user.name %>
                            </h3>
                            <p class="text-xs text-slate-500 dark:text-slate-400 truncate">Student</p>
                        </div>
                    </div>
                </div>
                <!-- Nav Links -->
                <nav class="space-y-1">
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium"
                        href="/student/home">
                        <span class="material-symbols-outlined fill-1">home</span>
                        Home
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg bg-primary/10 text-primary font-medium"
                        href="/student/dashboard">
                        <span class="material-symbols-outlined">messages</span>
                        Messages
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium"
                        href="/student/mentors">
                        <span class="material-symbols-outlined">group</span>
                        Mentors
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium"
                        href="/student/opportunities">
                        <span class="material-symbols-outlined">work</span>
                        Jobs &amp; Internships
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium"
                        href="/student/events">
                        <span class="material-symbols-outlined">event</span>
                        Events
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium"
                        href="/student/resources">
                        <span class="material-symbols-outlined">folder_open</span>
                        Resources
                    </a>
                    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 hover:text-slate-900 dark:hover:text-white transition-colors font-medium"
                        href="/student/counselor">
                        <span class="material-symbols-outlined">smart_toy</span>
                        AI Counselor
                    </a>
                </nav>
            </div>
            <div class="p-4 mt-auto">
                <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors text-sm font-medium"
                    href="#">
                    <span class="material-symbols-outlined">settings</span>
                    Settings
                </a>
                <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-600 dark:text-slate-400 hover:text-red-600 transition-colors text-sm font-medium"
                    href="/auth/logout">
                    <span class="material-symbols-outlined">logout</span>
                    Log Out
                </a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="flex-1 overflow-y-auto overflow-x-hidden bg-background-light dark:bg-background-dark relative">
            <!-- Dashboard Content Scrollable -->
            <div class="flex-1 overflow-y-auto custom-scrollbar p-6 lg:p-8">
                <!-- Welcome & Stats Section -->
                <div class="mb-8">
                    <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Welcome back, <%=
                            user.name.split(' ')[0] %></h1>
                    <p class="text-slate-500 dark:text-slate-400 mb-6">Here' s what's happening with your mentorship
                            journey today.</p>
                </div>
                <!-- Main Layout Grid: Chat & Resources -->
                <!-- Main Layout: Full Width Chat Hub -->
                <div class="h-[700px] mb-10">
                    <!-- Chat Container -->
                    <div
                        class="w-full bg-white dark:bg-slate-800 rounded-3xl border border-slate-200 dark:border-slate-700 shadow-2xl flex overflow-hidden h-full">

                        <!-- Left Sidebar: Mentors List -->
                        <div
                            class="w-1/4 min-w-[320px] border-r border-slate-200 dark:border-slate-700 flex flex-col bg-slate-50 dark:bg-slate-800/50">
                            <div
                                class="p-8 border-b border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800/80 backdrop-blur-md">
                                <h3 class="font-bold text-slate-900 dark:text-white">Direct Messages</h3>
                                <p class="text-xs text-slate-400 mt-1 font-bold uppercase tracking-widest opacity-70">
                                    Connected Mentors</p>
                            </div>

                            <div class="flex-1 overflow-y-auto custom-scrollbar">
                                <% if (connectedMentors.length===0) { %>
                                    <div
                                        class="flex flex-col items-center justify-center h-full px-10 py-16 text-center">
                                        <div
                                            class="w-20 h-20 rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center mb-8 shadow-inner text-slate-300">
                                            <span class="material-symbols-outlined text-4xl">chat_bubble</span>
                                        </div>
                                        <p class="text-base text-slate-500 font-extrabold mb-6">No connections yet.</p>
                                        <a href="/student/mentors"
                                            class="inline-flex items-center gap-3 px-8 py-3.5 bg-primary text-white rounded-2xl text-sm font-black shadow-xl shadow-primary/30 hover:scale-105 transition-all">
                                            Search Mentors <span
                                                class="material-symbols-outlined text-base">arrow_forward</span>
                                        </a>
                                    </div>
                                    <% } else { %>
                                        <% connectedMentors.forEach((mentor, idx)=> { %>
                                            <div onclick="openChat('<%= mentor._id %>', '<%= mentor.name %>')"
                                                id="contact-<%= mentor._id %>"
                                                class="contact-item px-8 py-6 cursor-pointer hover:bg-white dark:hover:bg-slate-700/80 transition-all border-b border-slate-100 dark:border-slate-700/30 group <%= idx === 0 ? 'bg-white dark:bg-slate-700/90 border-l-[6px] border-primary' : '' %>">
                                                <div class="flex items-center gap-5">
                                                    <div class="relative shrink-0">
                                                        <div
                                                            class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary font-black text-2xl group-hover:scale-110 transition-transform">
                                                            <%= mentor.name.charAt(0).toUpperCase() %>
                                                        </div>
                                                        <div
                                                            class="absolute -bottom-1 -right-1 w-4 h-4 bg-green-500 border-[3px] border-slate-50 dark:border-slate-800 rounded-full shadow-sm">
                                                        </div>
                                                    </div>
                                                    <div class="flex-1 min-w-0">
                                                        <h4
                                                            class="font-black text-base text-slate-900 dark:text-white truncate mb-1 letter-tight">
                                                            <%= mentor.name %>
                                                        </h4>
                                                        <p
                                                            class="text-[10px] font-black text-slate-400 dark:text-slate-500 truncate uppercase tracking-[0.15em]">
                                                            <%= mentor.jobTitle || mentor.domain || 'Expert Advisor' %>
                                                        </p>
                                                    </div>
                                                </div>
                                            </div>
                                            <% }) %>
                                                <% } %>
                            </div>
                        </div>

                        <!-- Right Area: Chat Content -->
                        <div class="flex-1 flex flex-col bg-white dark:bg-slate-800" id="chat-area">
                            <!-- Placeholder -->
                            <div id="chat-placeholder"
                                class="flex-1 flex flex-col items-center justify-center text-slate-400 p-16 text-center">
                                <div
                                    class="w-40 h-40 rounded-[2.5rem] bg-slate-50 dark:bg-slate-900 flex items-center justify-center mb-10 shadow-inner rotate-3 hover:rotate-0 transition-transform duration-700">
                                    <span
                                        class="material-symbols-outlined text-8xl text-slate-200 dark:text-slate-700">forum</span>
                                </div>
                                <h3 class="text-3xl font-black text-slate-900 dark:text-white mb-4">Select a Mentor</h3>
                                <p class="text-slate-400 max-w-sm mx-auto font-bold text-lg leading-relaxed opacity-70">
                                    Pick a mentor from the sidebar to open your direct communication hub.</p>
                            </div>

                            <!-- Active Chat Panel -->
                            <div id="active-chat" class="hidden flex-1 flex flex-col h-full overflow-hidden">
                                <!-- Header -->
                                <div
                                    class="h-28 px-12 border-b border-slate-200 dark:border-slate-700 flex items-center justify-between shrink-0 bg-white/40 dark:bg-slate-800/40 backdrop-blur-2xl">
                                    <div class="flex items-center gap-6">
                                        <div class="w-14 h-14 rounded-2xl bg-primary text-white flex items-center justify-center font-black shadow-2xl shadow-primary/30"
                                            id="chat-avatar">?</div>
                                        <div>
                                            <h3 class="font-black text-slate-900 dark:text-white" id="chat-name">–</h3>
                                            <div class="flex items-center gap-2 mt-1.5">
                                                <div
                                                    class="w-2.5 h-2.5 bg-green-500 rounded-full animate-pulse shadow-glow shadow-green-500">
                                                </div>
                                                <p class="text-xs text-green-500 font-black uppercase tracking-widest">
                                                    Active Now</p>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- <div class="flex gap-3">
                                        <button
                                            class="w-12 h-12 flex items-center justify-center bg-slate-100 dark:bg-slate-700 rounded-2xl text-slate-500 hover:text-primary transition-all hover:scale-110 active:scale-95">
                                            <span class="material-symbols-outlined font-bold">call</span>
                                        </button>
                                        <button
                                            class="w-12 h-12 flex items-center justify-center bg-slate-100 dark:bg-slate-700 rounded-2xl text-slate-500 hover:text-primary transition-all hover:scale-110 active:scale-95">
                                            <span class="material-symbols-outlined font-bold">videocam</span>
                                        </button>
                                    </div> -->
                                </div>

                                <!-- Message Stream -->
                                <div class="flex-1 overflow-y-auto custom-scrollbar p-12 space-y-8 bg-slate-50/20 dark:bg-slate-900/50"
                                    id="chat-messages"></div>

                                <!-- Composer -->
                                <div
                                    class="p-10 bg-white dark:bg-slate-800 border-t border-slate-200 dark:border-slate-700 shrink-0">
                                    <div class="flex items-center gap-6 max-w-6xl mx-auto">
                                        <div class="flex-1 relative group">
                                            <div
                                                class="absolute inset-y-0 left-6 flex items-center pointer-events-none text-slate-400 group-focus-within:text-primary transition-colors">
                                                <span
                                                    class="material-symbols-outlined font-bold text-[24px]">chat_bubble</span>
                                            </div>
                                            <input id="msg-input"
                                                class="w-full bg-slate-100/50 dark:bg-slate-900/50 border-2 border-transparent focus:border-primary/20 rounded-[1.5rem] py-5 pl-16 pr-8 text-base font-bold transition-all placeholder:text-slate-400 dark:placeholder:text-slate-600"
                                                placeholder="Share your thoughts with your mentor..." type="text"
                                                onkeydown="if(event.key==='Enter') sendMessage()" />
                                        </div>
                                        <button onclick="sendMessage()"
                                            class="w-18 h-18 bg-primary hover:bg-blue-700 text-white rounded-2xl shadow-3xl shadow-primary/40 transition-all active:scale-90 flex items-center justify-center shrink-0 group">
                                            <span
                                                class="material-symbols-outlined text-[32px] group-hover:rotate-12 transition-transform">send</span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
        </main>
    </div>

    <!-- ─── Chat JS ─────────────────────────────────────────── -->
    <script>
        let currentUserId = null;
        let pollInterval = null;

        function openChat(userId, userName) {
            currentUserId = userId;

            // Highlight selected contact
            document.querySelectorAll('.contact-item').forEach(el => {
                el.classList.remove('bg-white', 'dark:bg-slate-700', 'border-l-4', 'border-primary');
            });
            const selected = document.getElementById('contact-' + userId);
            if (selected) {
                selected.classList.add('bg-white', 'dark:bg-slate-700', 'border-l-4', 'border-primary');
            }

            // Show chat panel
            document.getElementById('chat-placeholder').classList.add('hidden');
            const activeChat = document.getElementById('active-chat');
            activeChat.classList.remove('hidden');
            activeChat.classList.add('flex');

            // Set header
            document.getElementById('chat-name').textContent = userName;
            document.getElementById('chat-avatar').textContent = userName.charAt(0).toUpperCase();

            // Load messages
            loadMessages();

            // Start polling
            clearInterval(pollInterval);
            pollInterval = setInterval(loadMessages, 3000);
        }

        async function loadMessages() {
            if (!currentUserId) return;
            try {
                const res = await fetch('/api/messages/' + currentUserId);
                const data = await res.json();
                renderMessages(data.messages || []);
            } catch (e) {
                console.error('Load error:', e);
            }
        }

        function renderMessages(messages) {
            const box = document.getElementById('chat-messages');
            if (messages.length === 0) {
                box.innerHTML = '<div class="text-center text-xs text-slate-400 py-8">No messages yet. Say hello! 👋</div>';
                return;
            }
            box.innerHTML = messages.map(m => {
                if (m.mine) {
                    return `<div class="flex flex-row-reverse gap-2">
                        <div class="flex flex-col items-end gap-1 max-w-[75%]">
                            <div class="bg-primary text-white px-3 py-2 rounded-2xl rounded-tr-none shadow-sm text-sm">${escHtml(m.content)}</div>
                            <span class="text-[10px] text-slate-400">${m.time}</span>
                        </div>
                    </div>`;
                } else {
                    return `<div class="flex gap-2">
                        <div class="w-7 h-7 rounded-full bg-primary/20 flex items-center justify-center text-primary text-xs shrink-0 mt-1">${escHtml(document.getElementById('chat-name').textContent.charAt(0))}</div>
                        <div class="flex flex-col gap-1 max-w-[75%]">
                            <div class="bg-white dark:bg-slate-700 border border-slate-200 dark:border-slate-600 px-3 py-2 rounded-2xl rounded-tl-none shadow-sm text-sm text-slate-700 dark:text-slate-200">${escHtml(m.content)}</div>
                            <span class="text-[10px] text-slate-400 ml-1">${m.time}</span>
                        </div>
                    </div>`;
                }
            }).join('');
            box.scrollTop = box.scrollHeight;
        }

        async function sendMessage() {
            const input = document.getElementById('msg-input');
            const content = input.value.trim();
            if (!content || !currentUserId) return;
            input.value = '';
            try {
                const res = await fetch('/api/messages/' + currentUserId, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content }),
                });
                const data = await res.json();
                if (data.message) {
                    // Optimistically append
                    await loadMessages();
                }
            } catch (e) {
                console.error('Send error:', e);
            }
        }

        function escHtml(str) {
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }

        // Auto-open first mentor if any
        window.addEventListener('DOMContentLoaded', () => {
            const first = document.querySelector('.contact-item');
            if (first) first.click();
        });
    </script>
</body>

</html>